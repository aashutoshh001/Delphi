# Copy this file to `.env` and fill in your own keys. `.env` is gitignored —
# never commit real keys.

# --- LiteLLM (active LLM backend — SHL internal endpoint) --------------------
# HYPOTHESIS_AGENT__BACKENDS__LLM=litellm switches the agent off the offline
# MockLLMService and onto this endpoint for real runs (the server,
# examples/run_local_demo.py if you edit it, direct HypothesisAgent use).
# Tests and the demo force backends.llm back to "mock" explicitly in code,
# so they stay offline/deterministic regardless of what's set here.
#
# If your gateway expects a specific model identifier (possibly prefixed,
# e.g. "openai/<model-name>"), also set HYPOTHESIS_AGENT__LLM__MODEL.
HYPOTHESIS_AGENT__BACKENDS__LLM=litellm
LITELLM_API_BASE=https://labs.shl.com/llm-internal/
LITELLM_API_KEY=

# --- OpenAI (used if backends.llm=openai / backends.embedding=openai) -------
OPENAI_API_KEY=

# --- Langfuse (optional LLM call tracing/observability) -----------------
# Leave blank to skip tracing entirely — nothing else changes. If set,
# requires the `observability` extra installed (pinned langfuse<3, see
# pyproject.toml). Picked up automatically by litellm's built-in callback;
# no application code references these directly.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# --- Server -------------------------------------------------------------
HYPOTHESIS_AGENT_SERVER_HOST=127.0.0.1
HYPOTHESIS_AGENT_SERVER_PORT=8200

# Only needed to opt into tests/integration/test_live_backends.py.
RUN_LIVE_TESTS=0
